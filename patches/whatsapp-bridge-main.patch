+// ---------------------------------------------------------------------------
+// Ban-avoidance: outbound throttle state
+// ---------------------------------------------------------------------------
+
+// sendMu serialises outbound sends so that gap + jitter are applied correctly
+// even if multiple goroutines hit /api/send concurrently.
+var (
+	sendMu       sync.Mutex
+	lastSendTime time.Time
+)
+
+// getEnvIntDefault reads an integer env var, returning def when the variable is
+// absent or not parseable.
+func getEnvIntDefault(key string, def int) int {
+	v := os.Getenv(key)
+	if v == "" {
+		return def
+	}
+	n, err := strconv.Atoi(v)
+	if err != nil {
+		return def
+	}
+	return n
+}
+
+// applyOutboundThrottle sleeps before every outbound send to produce
+// human-paced message timing.
+//
+// Env vars (all in milliseconds):
+//
+//	WA_SEND_MIN_MS  — lower bound of the random per-send delay  (default 1500)
+//	WA_SEND_MAX_MS  — upper bound of the random per-send delay  (default 5000)
+//	WA_SEND_GAP_MS  — minimum wall-clock gap between any two sends (default 1200)
+//
+// Set all three to 0 to disable throttling entirely.
+func applyOutboundThrottle() {
+	minMs := getEnvIntDefault("WA_SEND_MIN_MS", 1500)
+	maxMs := getEnvIntDefault("WA_SEND_MAX_MS", 5000)
+	gapMs := getEnvIntDefault("WA_SEND_GAP_MS", 1200)
+
+	// Bypass when all three are explicitly zeroed.
+	if minMs == 0 && maxMs == 0 && gapMs == 0 {
+		return
+	}
+
+	// Hold the mutex for the entire sleep so that concurrent senders queue
+	// and each one waits the full gap from the previous send.
+	sendMu.Lock()
+	defer sendMu.Unlock()
+
+	// 1. Enforce minimum gap since the last send.
+	if gapMs > 0 && !lastSendTime.IsZero() {
+		elapsed := time.Since(lastSendTime)
+		gap := time.Duration(gapMs) * time.Millisecond
+		if elapsed < gap {
+			time.Sleep(gap - elapsed)
+		}
+	}
+
+	// 2. Add a randomised human-paced delay on top of the gap.
+	if minMs > 0 || maxMs > 0 {
+		hi := maxMs
+		if hi < minMs {
+			hi = minMs
+		}
+		spread := hi - minMs
+		var delay time.Duration
+		if spread > 0 {
+			delay = time.Duration(minMs+rand.Intn(spread+1)) * time.Millisecond
+		} else {
+			delay = time.Duration(minMs) * time.Millisecond
+		}
+		if delay > 0 {
+			time.Sleep(delay)
+		}
+	}
+
+	// 3. Record the send time while still holding the mutex so the next
+	//    caller's gap calculation is accurate.
+	lastSendTime = time.Now()
+}
+
+// hasReceivedMessageFromJID returns true when the local message store contains
+// at least one inbound message (is_from_me = false) from the given JID.
+// Used to enforce WA_REACTIVE_ONLY mode.
+func hasReceivedMessageFromJID(messageStore *MessageStore, recipient string) (bool, error) {
+	// Normalise to a full JID string (e.g. "491701234567@s.whatsapp.net").
+	jid := recipient
+	if !strings.Contains(jid, "@") {
+		jid = jid + "@s.whatsapp.net"
+	}
+	var count int
+	err := messageStore.db.QueryRow(
+		"SELECT COUNT(*) FROM messages WHERE chat_jid = ? AND is_from_me = 0",
+		jid,
+	).Scan(&count)
+	if err != nil {
+		return false, err
+	}
+	return count > 0, nil
+}
